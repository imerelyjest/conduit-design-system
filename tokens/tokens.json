{
  "$schema": "https://schemas.dev.tokens.studio/v1.json",
  "meta": {
    "name": "Conduit Systems Design System",
    "version": "1.0.0",
    "owner": "Conduit Systems",
    "site": "https://conduitsystems.org",
    "exported": "2026-05-08",
    "theme": "light"
  },

  "color": {
    "anchor": {
      "text":       { "value": "#040316", "type": "color", "description": "Body copy, headings on light backgrounds. Fixed cost — outside the 60/30/10 ratio." },
      "background": { "value": "#FBFBFE", "type": "color", "description": "Default page background. 60% of any layout." },
      "primary":    { "value": "#FF4529", "type": "color", "description": "CTAs, brand accent, key highlights. 10% of any layout." },
      "secondary":  { "value": "#212121", "type": "color", "description": "Strong contrast surfaces, dark UI. 30% of any layout." },
      "accent":     { "value": "#B7C8D7", "type": "color", "description": "Trim color — borders, dividers, soft fills. Under 5% of any layout." }
    },
    "primary": {
      "hover":   { "value": "#E63E25", "type": "color", "description": "Primary hover (top of gradient -> bottom)" },
      "pressed": { "value": "#D43820", "type": "color", "description": "Primary active/pressed state" },
      "tint-light":  { "value": "#FF5A41", "type": "color", "description": "Hover top stop — gradient brightens upward" }
    },
    "muted":     { "value": "#6B7280", "type": "color", "description": "Secondary text, captions" },
    "surface": {
      "card":     { "value": "#FFFFFF", "type": "color" },
      "card-soft": { "value": "#F4F5F8", "type": "color", "description": "Bottom of secondary button gradient" },
      "card-pressed": { "value": "#ECEEF3", "type": "color" }
    },
    "border": {
      "subtle":  { "value": "rgba(183, 200, 215, 0.4)",  "type": "color", "description": "accent/40 — default section dividers" },
      "default": { "value": "rgba(183, 200, 215, 0.6)",  "type": "color", "description": "accent/60" },
      "strong":  { "value": "rgba(33, 33, 33, 0.18)",    "type": "color", "description": "Secondary button border" }
    },
    "shadow": {
      "primary-glow":   { "value": "0 4px 12px rgba(255, 69, 41, 0.25)", "type": "shadow" },
      "primary-glow-lg":{ "value": "0 6px 20px rgba(255, 69, 41, 0.40)", "type": "shadow" },
      "card":           { "value": "0 1px 3px rgba(15, 23, 42, 0.08)",   "type": "shadow" },
      "card-hover":     { "value": "0 4px 14px rgba(15, 23, 42, 0.12)",  "type": "shadow" }
    }
  },

  "gradient": {
    "primary-secondary":        { "value": "linear-gradient(#FF4529, #212121)", "type": "gradient" },
    "primary-accent":           { "value": "linear-gradient(#FF4529, #B7C8D7)", "type": "gradient" },
    "secondary-accent":         { "value": "linear-gradient(#212121, #B7C8D7)", "type": "gradient" },
    "primary-secondary-radial": { "value": "radial-gradient(#FF4529, #212121)", "type": "gradient" },
    "primary-accent-radial":    { "value": "radial-gradient(#FF4529, #B7C8D7)", "type": "gradient" },
    "secondary-accent-radial":  { "value": "radial-gradient(#212121, #B7C8D7)", "type": "gradient" },
    "btn-primary":   { "value": "linear-gradient(180deg, #FF4529 0%, #E63E25 100%)", "type": "gradient" },
    "btn-primary-hover":  { "value": "linear-gradient(180deg, #FF5A41 0%, #FF4529 100%)", "type": "gradient" },
    "btn-secondary": { "value": "linear-gradient(180deg, #FFFFFF 0%, #F4F5F8 100%)", "type": "gradient" }
  },

  "typography": {
    "fontFamily": {
      "display": { "value": "Plus Jakarta Sans, system-ui, sans-serif", "type": "fontFamily" },
      "sans":    { "value": "DM Sans, system-ui, sans-serif",            "type": "fontFamily" },
      "mono":    { "value": "ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, monospace", "type": "fontFamily" }
    },
    "fontWeight": {
      "regular": { "value": 400, "type": "fontWeight" },
      "medium":  { "value": 500, "type": "fontWeight" },
      "bold":    { "value": 700, "type": "fontWeight" }
    },
    "scale": {
      "h1":    { "value": "67.36px", "rem": "4.210rem", "type": "fontSize", "lineHeight": 1.05, "letterSpacing": "-0.02em",  "weight": 700, "family": "display", "fluid": "clamp(2.5rem, 6vw + 1rem, 4.21rem)" },
      "h2":    { "value": "50.56px", "rem": "3.158rem", "type": "fontSize", "lineHeight": 1.10, "letterSpacing": "-0.015em", "weight": 700, "family": "display", "fluid": "clamp(2rem, 4vw + 0.75rem, 3.158rem)" },
      "h3":    { "value": "37.92px", "rem": "2.369rem", "type": "fontSize", "lineHeight": 1.20, "weight": 700, "family": "display" },
      "h4":    { "value": "28.48px", "rem": "1.777rem", "type": "fontSize", "lineHeight": 1.25, "weight": 700, "family": "display" },
      "h5":    { "value": "21.28px", "rem": "1.333rem", "type": "fontSize", "lineHeight": 1.30, "weight": 700, "family": "display" },
      "body":  { "value": "16px",    "rem": "1rem",     "type": "fontSize", "lineHeight": 1.50, "weight": 400, "family": "sans" },
      "small": { "value": "12px",    "rem": "0.75rem",  "type": "fontSize", "lineHeight": 1.40, "weight": 400, "family": "sans" }
    },
    "scaleRatio": { "value": 1.333, "type": "number", "description": "Perfect fourth" }
  },

  "spacing": {
    "0":  { "value": "0",     "type": "spacing" },
    "1":  { "value": "4px",   "type": "spacing" },
    "2":  { "value": "8px",   "type": "spacing" },
    "3":  { "value": "12px",  "type": "spacing" },
    "4":  { "value": "16px",  "type": "spacing" },
    "5":  { "value": "20px",  "type": "spacing" },
    "6":  { "value": "24px",  "type": "spacing" },
    "8":  { "value": "32px",  "type": "spacing" },
    "10": { "value": "40px",  "type": "spacing" },
    "12": { "value": "48px",  "type": "spacing" },
    "16": { "value": "64px",  "type": "spacing" },
    "20": { "value": "80px",  "type": "spacing" },
    "24": { "value": "96px",  "type": "spacing" },
    "32": { "value": "128px", "type": "spacing" }
  },

  "radius": {
    "sm":   { "value": "6px",  "type": "borderRadius" },
    "md":   { "value": "12px", "type": "borderRadius" },
    "lg":   { "value": "18px", "type": "borderRadius" },
    "xl":   { "value": "24px", "type": "borderRadius" },
    "2xl":  { "value": "32px", "type": "borderRadius" },
    "pill": { "value": "9999px", "type": "borderRadius", "description": "Buttons, pills, chips" }
  },

  "motion": {
    "duration": {
      "instant": { "value": "100ms", "type": "duration" },
      "fast":    { "value": "200ms", "type": "duration", "description": "Button states" },
      "base":    { "value": "240ms", "type": "duration" },
      "card":    { "value": "320ms", "type": "duration", "description": "Card slide-in" },
      "scene":   { "value": "700ms", "type": "duration", "description": "3D plane transitions" }
    },
    "easing": {
      "out-expo":  { "value": "cubic-bezier(0.2, 0.7, 0.2, 1)", "type": "cubicBezier", "description": "House easing — confident, decisive" },
      "in-out":    { "value": "ease-in-out", "type": "cubicBezier" },
      "linear":    { "value": "linear",      "type": "cubicBezier" }
    }
  },

  "elevation": {
    "0": { "value": "none", "type": "shadow" },
    "1": { "value": "0 1px 2px rgba(15, 23, 42, 0.06)", "type": "shadow" },
    "2": { "value": "0 1px 3px rgba(15, 23, 42, 0.08), 0 1px 2px rgba(15, 23, 42, 0.04)", "type": "shadow" },
    "3": { "value": "0 4px 14px rgba(15, 23, 42, 0.12)", "type": "shadow" },
    "4": { "value": "0 24px 50px -20px rgba(20, 25, 40, 0.18), 0 50px 100px -40px rgba(20, 25, 40, 0.18)", "type": "shadow", "description": "Glass plane resting" },
    "primary-glow": { "value": "0 4px 12px rgba(255, 69, 41, 0.25)", "type": "shadow" },
    "primary-glow-strong": { "value": "0 6px 20px rgba(255, 69, 41, 0.40)", "type": "shadow" }
  },

  "layout": {
    "container": {
      "max":        { "value": "1280px", "type": "size", "description": "max-w-7xl — main content container" },
      "narrow":     { "value": "1024px", "type": "size", "description": "max-w-5xl — hero, focal copy" },
      "prose":      { "value": "62ch",   "type": "size", "description": "Body paragraph max width for readability" }
    },
    "section": {
      "padding-y-mobile":  { "value": "64px",  "type": "spacing" },
      "padding-y-desktop": { "value": "96px",  "type": "spacing" },
      "padding-y-hero":    { "value": "176px", "type": "spacing" }
    }
  },

  "ratio": {
    "60-30-10": {
      "background": { "value": 0.60, "color": "#FBFBFE", "description": "Dominant — page surfaces, cards, white space" },
      "secondary":  { "value": 0.30, "color": "#212121", "description": "Supporting — dark sections, headers, footers" },
      "primary":    { "value": 0.10, "color": "#FF4529", "description": "Accent — CTAs, links, key highlights" },
      "accent":     { "value": "<5%", "color": "#B7C8D7", "description": "Trim — borders, dividers, decorative" }
    }
  }
}
